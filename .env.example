# Copy to .env and fill in. .env is gitignored.

# --- Cloudflare Access ---
# Zero Trust team domain, e.g. "crbox.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=crbox.cloudflareaccess.com
# Application AUD tag, created when you add an Access app for alerts.crbox.ca.
# Find it under Access -> Applications -> your app -> Overview.
# Leave empty to bypass auth in local dev.
CF_ACCESS_AUD=

# --- App ---
LOG_LEVEL=INFO

# RSS polling — Google Alerts updates are infrequent, 30m is plenty.
POLL_INTERVAL_MINUTES=30
POLL_CONCURRENCY=4

# Nightly SQLite backup (UTC hour, 0-23) + retention
BACKUP_HOUR=4
BACKUP_KEEP_DAYS=30

# Drop item rows older than this; saved items are preserved regardless.
# Set to 0 to keep everything forever.
ITEM_RETENTION_DAYS=180
