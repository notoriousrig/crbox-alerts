# Copy to .env and fill in. .env is gitignored.

# --- Cloudflare Access ---
# Zero Trust team domain, e.g. "crbox.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=crbox.cloudflareaccess.com
# Application AUD tag, created when you add an Access app for alerts.crbox.ca.
# Find it under Access -> Applications -> your app -> Overview.
# Leave empty to bypass auth in local dev.
CF_ACCESS_AUD=

# --- Gmail OAuth (from Google Cloud Console) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public origin used to build the OAuth redirect URI. Must exactly
# match the "Authorized redirect URIs" entry in Google Cloud Console
# (path /api/auth/google/callback is appended). Empty = derive from
# request host (use for local dev).
PUBLIC_BASE_URL=https://alerts.crbox.ca

# --- App ---
LOG_LEVEL=INFO

# Poll Gmail every N minutes. 30 is plenty for Google Alerts.
POLL_INTERVAL_MINUTES=30
# How far back to scan each poll. Bounds Gmail API quota usage.
GMAIL_LOOKBACK_DAYS=7

# Nightly SQLite backup (UTC hour, 0-23) + retention
BACKUP_HOUR=4
BACKUP_KEEP_DAYS=30

# Drop item rows older than this; saved items are preserved regardless.
# Set to 0 to keep everything forever.
ITEM_RETENTION_DAYS=180
